# Marketing Team Template - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# GEMINI API (Required for image generation + video analysis)
# ============================================
# Get your API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# META MARKETING API (Required for ads publishing)
# ============================================
# Follow setup guide in TOOLS.md
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_account_id_here
META_PAGE_ID=your_facebook_page_id_here
